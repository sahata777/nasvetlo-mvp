# === NA SVETLO MVP Environment ===

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (alternative)
# OPENAI_API_KEY=sk-...

# WordPress
WP_URL=https://your-wordpress-site.com
WP_USERNAME=your-wp-username
WP_APPLICATION_PASSWORD=your-wp-app-password-here

# Telegram (optional)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Database
DATABASE_URL=sqlite:///nasvetlo.db

# Config file path
NASVETLO_CONFIG=config.yaml

# Log level
LOG_LEVEL=INFO
